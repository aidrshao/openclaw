\":null,\"siteSettings\":{\"siteDomain\":\"www.theverge.com\",\"siteSlug\":\"theverge\",\"siteTitle\":\"The Verge\",\"siteTagline\":\"The Verge is about technology and how it makes us feel. Founded in 2011, we offer our audience everything from breaking news to reviews to award-winning features and investigations, on our site, in video, and in podcasts.\",\"placeholderImage\":{\"thumbnails\":{\"horizontal\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=10.625,0,78.75,100\"},\"vertical\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=29,0,42,100\"},\"square\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=23.75,0,52.5,100\"},\"social\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=0,0.13712291199202,100,99.725754176016\"}},\"id\":\"dmcyOmltYWdlOjU2Mjk3OA==\"},\"siteLogo\":{\"originalWidth\":1200,\"originalHeight\":630,\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\",\"cropCoordinates\":{\"height\":100,\"width\":100}},\"social\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/01/verge-placeholder_f212b3.png?quality=90\\u0026strip=all\\u0026crop=0,0.13712291199202,100,99.725754176016\",\"cropCoordinates\":{\"height\":99.72575417601595,\"width\":100}}},\"id\":\"dmcyOmltYWdlOjU2Mjk3OA==\"},\"socialMediaLinks\":[],\"seo\":null},\"newsletters\":[{\"title\":\"The Verge Daily\",\"slug\":\"verge-daily\",\"listId\":\"Verge Daily\",\"default\":true,\"promoText\":{\"html\":\"A free daily digest of the news that matters most.\"},\"frequency\":\"daily\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/The-Verge-Daily-Newsletter-Header-1.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgzMA==\"}},{\"title\":\"Installer\",\"slug\":\"installer\",\"listId\":\"Installer\",\"default\":false,\"promoText\":{\"html\":\"A weekly newsletter by David Pierce designed to tell you everything you need to download, watch, read, listen to, and explore that fits in The Verge’s universe.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/Installer-Newsletter-Header-1.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgzMQ==\"}},{\"title\":\"Verge Deals\",\"slug\":\"deals\",\"listId\":\"Verge Deals\",\"default\":false,\"promoText\":{\"html\":\"Sign up for Verge Deals to get deals on products we’ve tested sent to your inbox weekly.\"},\"frequency\":\"daily\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/Verge-Deals-Newsletter-Header-1.jpg?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgzNA==\"}},{\"title\":\"Command Line\",\"slug\":\"command-line\",\"listId\":\"Command Line Active Subscribers\",\"default\":false,\"promoText\":{\"html\":\"The tech world’s inside conversation, as heard by Alex Heath.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/Command-Line-Newsletter-Header-1.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgxNg==\"}},{\"title\":\"Notepad\",\"slug\":\"notepad\",\"listId\":\"Notepad Active Subscribers\",\"default\":false,\"promoText\":{\"html\":\"A weekly window into Microsoft’s era-defining bets on AI, gaming, and the future of computing by Tom Warren.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/Notepad-Newsletter-Header-1.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgxOQ==\"}},{\"title\":\"Regulator\",\"slug\":\"regulator\",\"listId\":\"Regulator Active Subscribers\",\"default\":false,\"promoText\":{\"html\":\"A weekly newsletter unpacking the collision of Big Tech and the White House.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/Regulator-Newsletter-Header.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgyNA==\"}},{\"title\":\"The Stepback\",\"slug\":\"the-stepback\",\"listId\":\"The Stepback Active Subscribers\",\"default\":false,\"promoText\":{\"html\":\"A weekly newsletter delivering the deeper story behind The Verge’s biggest beats.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/08/The-Stepback-Newsletter-Header-1.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjcxOTgyOQ==\"}},{\"title\":\"Optimizer\",\"slug\":\"optimizer\",\"listId\":\"Optimizer Active Subscribers\",\"default\":false,\"promoText\":{\"html\":\"A weekly newsletter exploring the latest wellness gizmos and potions.\"},\"frequency\":\"weekly\",\"image\":{\"thumbnails\":{\"original\":{\"url\":\"https://platform.theverge.com/wp-content/uploads/sites/2/2025/09/Optimizer-sign-up-page.png?quality=90\\u0026strip=all\\u0026crop=0,0,100,100\"}},\"id\":\"dmcyOmltYWdlOjc2OTE2MQ==\"}}],\"mainNav\":{\"menuItems\":{\"nodes\":[{\"label\":\"Tech\",\"url\":\"https://www.theverge.com/tech\",\"menuItems\":[{\"label\":\"Amazon\",\"url\":\"https://www.theverge.com/amazon\",\"id\":\"dmcyOk5hdk1lbnVJdGVtVHlwZTo4MTA1MTQ=\"},{\"label\":\"Apple\",\"url\":\"https://www.thev